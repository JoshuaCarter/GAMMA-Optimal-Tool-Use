--[[
	Dorn's Optimal Tool Use

	GAMMA (Disassembly Item Tweaks) already picks the worst tool *type* for each
	item (grooming < swiss < leatherman). We must not change that — only redirect
	wear to the lowest-condition stack of whatever type was chosen.

	Loads late (zzzz_) so we wrap whatever func_disassembly / get_suitable_dtool
	GAMMA mods installed last.
]]

local MOD_ID = "dorn_optimal_tool_use"
local DORN_COMMON_VERSION = "dorn_common_f575cc9b" -- managed by sync-dorn-common.sh, do not hand-edit

local DORN

local CONFIG = {
	enabled = true,
	debug_log = false,
}

local orig_get_suitable_dtool = nil
local orig_func_disassembly = nil

local function log(msg)
	if not (DORN and DORN.dbg) then
		return
	end
	if CONFIG.debug_log then
		DORN.dbg.log(MOD_ID, tostring(msg))
	end
end

local function on_option_change()
	CONFIG.enabled = DORN.mcm.bool(MOD_ID, "main/enabled", true)
	CONFIG.debug_log = DORN.mcm.bool(MOD_ID, "development/debug_log", false)
end

local function redirect_to_lowest_stack(obj_d, note)
	if not (CONFIG.enabled and obj_d and db.actor) then
		return obj_d
	end
	local diss_tools = GetItemList("disassemble")

	-- read DIT break thresholds (matches Disassembly Item Tweaks is_breaking())
	local limits = { leatherman_limit = 10, swiss_limit = 10, grooming_limit = 10 }
	if dit_mcm and dit_mcm.get_config then
		limits.leatherman_limit = dit_mcm.get_config("leatherman_limit") or limits.leatherman_limit
		limits.swiss_limit = dit_mcm.get_config("swiss_limit") or limits.swiss_limit
		limits.grooming_limit = dit_mcm.get_config("grooming_limit") or limits.grooming_limit
	end

	local sec = obj_d:section()

	-- pick lowest-condition stack of this section that survives the use
	local optimal, best_cond = nil, nil
	local candidates = {}
	db.actor:iterate_inventory(function(_, item)
		if item:section() == sec then
			candidates[#candidates + 1] = item
		end
	end)
	for i = 1, #candidates do
		local tool = candidates[i]
		local degr = diss_tools[tool:section()]
		local survives
		if degr and degr > 0 and tool:condition() <= degr then
			survives = false
		elseif not degr or degr <= 0 then
			survives = true
		else
			local tool_sec = tool:section()
			local margin = 0
			if tool_sec == "leatherman_tool" then
				margin = limits.leatherman_limit / 100
			elseif tool_sec == "swiss_knife" then
				margin = limits.swiss_limit / 100
			elseif tool_sec == "grooming" then
				margin = limits.grooming_limit / 100
			end
			survives = degr < (tool:condition() - margin)
		end
		if survives then
			local cond = tool:condition()
			if not optimal or cond < best_cond then
				optimal = tool
				best_cond = cond
			end
		end
	end

	if optimal and optimal:id() ~= obj_d:id() then
		log(string.format(
			"%s %s cond=%.3f -> %s cond=%.3f",
			note or "redirect",
			sec,
			obj_d:condition(),
			optimal:section(),
			optimal:condition()
		))
		return optimal
	end
	if optimal then
		log(string.format("%s %s cond=%.3f (same stack)", note or "pick", sec, optimal:condition()))
	end
	return optimal or obj_d
end

local function optimal_get_suitable_dtool(obj)
	if not CONFIG.enabled then
		return orig_get_suitable_dtool(obj)
	end
	if not (obj and db.actor) then
		return orig_get_suitable_dtool(obj)
	end

	-- upstream (DIT / autolooter fix / vanilla) picks the tool *type* for this item
	local type_pick = orig_get_suitable_dtool(obj)
	if not type_pick then
		return nil
	end

	return redirect_to_lowest_stack(type_pick, "auto")
end

local function optimal_func_disassembly(obj, obj_d)
	if not CONFIG.enabled then
		return orig_func_disassembly(obj, obj_d)
	end

	-- explicit tool (drag-and-drop): keep type validation on what was dropped,
	-- but wear the lowest stack of that same section
	if obj_d and obj and db.actor and item_parts.is_suitable_dtool(obj, obj_d) then
		obj_d = redirect_to_lowest_stack(obj_d, "drag")
	end

	return orig_func_disassembly(obj, obj_d)
end

function on_game_start()
	DORN = _G[DORN_COMMON_VERSION].load(MOD_ID)

	on_option_change()

	orig_get_suitable_dtool = item_parts.get_suitable_dtool
	orig_func_disassembly = item_parts.func_disassembly
	item_parts.get_suitable_dtool = optimal_get_suitable_dtool
	item_parts.func_disassembly = optimal_func_disassembly

	RegisterScriptCallback("on_option_change", on_option_change)
end
