-- dorn_mcm_banner:begin (managed by sync-dorn-common.sh)
local DORN_COMMON_VERSION = "dorn_common_328e2e4d"
local function dorn_mcm()
	local hash = DORN_COMMON_VERSION:match("dorn_common_(.+)$")
	return _G["dorn_mcm_" .. hash]
end
-- dorn_mcm_banner:end



function on_mcm_load()
	local MCM = dorn_mcm()
	return {
		id = "dorn_optimal_tool_use",
		text = "ui_mcm_menu_dorn_optimal_tool_use",
		gr = {
			{
				id = "main",
				sh = true,
				text = "ui_mcm_dorn_optimal_tool_use_main_section",
				gr = MCM.with_header({
					{
						id = "main_description",
						type = "desc",
						text = "ui_mcm_dorn_optimal_tool_use_main_description",
					},
					{
						id = "enabled",
						type = "check",
						val = 1,
						def = true,
						hint = "dorn_optimal_tool_use_enabled",
					},
				},
			},
			{
				id = "development",
				sh = true,
				text = "ui_mcm_dorn_optimal_tool_use_development_section",
				gr = MCM.with_header({
					{
						id = "debug_log",
						type = "check",
						val = 1,
						def = false,
						hint = "dorn_optimal_tool_use_debug_log",
