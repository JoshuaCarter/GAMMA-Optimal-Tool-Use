--[[
	Dorn's Optimal Tool Use

	Vanilla disassembly burns the first / top-of-stack tool. We redirect both
	auto-selection and drag-and-drop to the lowest-condition instance that will
	still survive utils_item.degrade (condition > degradation cost).
]]

local MOD_ID = "dorn_optimal_tool_use"
local DORN_COMMON_VERSION = "dorn_common_7367f5e7" -- managed by sync-dorn-common.sh, do not hand-edit

local DORN

local CONFIG = {
	enabled = true,
	debug_log = false,
}

local LOG = {
	PICK = { order = 0, color = "green" },
}

local orig_get_suitable_dtool = nil
local orig_func_disassembly = nil

local function log(msg)
	if DORN and DORN.dbg and CONFIG.debug_log then
		DORN.dbg.write(MOD_ID, LOG.PICK.order, "[ToolUse] " .. tostring(msg), LOG.PICK.color)
	end
end

local function on_option_change()
	CONFIG.enabled = DORN.mcm.bool(MOD_ID, "main/enabled", true)
	CONFIG.debug_log = DORN.mcm.bool(MOD_ID, "development/debug_log", false)
	DORN.dbg.set_enabled(MOD_ID, CONFIG.debug_log)
end

local function tool_survives_use(tool_obj, degr_val)
	if not degr_val or degr_val <= 0 then
		return true
	end
	return tool_obj:condition() > degr_val
end

local function collect_inventory(filter_fn)
	local out = {}
	if not db.actor then
		return out
	end
	db.actor:iterate_inventory(function(_, item)
		if filter_fn(item) then
			out[#out + 1] = item
		end
	end)
	return out
end

local function pick_lowest_surviving(candidates, diss_tools)
	local best, best_cond = nil, nil
	for i = 1, #candidates do
		local tool = candidates[i]
		local degr = diss_tools[tool:section()]
		if tool_survives_use(tool, degr) then
			local cond = tool:condition()
			if not best or cond < best_cond then
				best = tool
				best_cond = cond
			end
		end
	end
	return best
end

local function pick_lowest_surviving_section(sec, diss_tools)
	return pick_lowest_surviving(collect_inventory(function(item)
		return item:section() == sec
	end), diss_tools)
end

local function log_pick(tool, obj, note)
	if tool and CONFIG.debug_log then
		log(string.format(
			"%s %s cond=%.3f for %s",
			note or "picked",
			tool:section(),
			tool:condition(),
			obj:section()
		))
	end
end

local function optimal_get_suitable_dtool(obj)
	if not CONFIG.enabled then
		return orig_get_suitable_dtool(obj)
	end
	if not (obj and db.actor) then
		return orig_get_suitable_dtool(obj)
	end

	local diss_tools = GetItemList("disassemble")
	local candidates

	if IsWeapon(obj) then
		candidates = collect_inventory(function(item)
			return item:section() == "leatherman_tool"
		end)
	else
		candidates = collect_inventory(function(item)
			return diss_tools[item:section()] ~= nil
		end)
	end

	local tool = pick_lowest_surviving(candidates, diss_tools)
	log_pick(tool, obj, "auto")
	return tool
end

local function optimal_func_disassembly(obj, obj_d)
	if not CONFIG.enabled then
		return orig_func_disassembly(obj, obj_d)
	end

	-- Explicit tool (drag-and-drop): keep validation on what the player dropped,
	-- but apply degradation to the lowest same-section survivor instead.
	if obj_d and obj and db.actor and item_parts.is_suitable_dtool(obj, obj_d) then
		local diss_tools = GetItemList("disassemble")
		local optimal = pick_lowest_surviving_section(obj_d:section(), diss_tools)
		if optimal and optimal:id() ~= obj_d:id() then
			log(string.format(
				"redirect %s cond=%.3f -> %s cond=%.3f for %s",
				obj_d:section(),
				obj_d:condition(),
				optimal:section(),
				optimal:condition(),
				obj:section()
			))
			obj_d = optimal
		end
	end

	return orig_func_disassembly(obj, obj_d)
end

function on_game_start()
	DORN = _G[DORN_COMMON_VERSION].load(MOD_ID)

	orig_get_suitable_dtool = item_parts.get_suitable_dtool
	orig_func_disassembly = item_parts.func_disassembly
	item_parts.get_suitable_dtool = optimal_get_suitable_dtool
	item_parts.func_disassembly = optimal_func_disassembly

	RegisterScriptCallback("on_option_change", on_option_change)
end
