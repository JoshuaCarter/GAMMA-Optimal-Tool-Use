<?xml version="1.0" encoding="windows-1251"?>
<string_table>
	<string id="ui_mcm_menu_dorn_optimal_tool_use">
		<text>Dorn's Optimal Tool Use</text>
	</string>
	<string id="ui_mcm_dorn_optimal_tool_use_main_section">
		<text>Main</text>
	</string>
	<string id="ui_mcm_dorn_optimal_tool_use_main_description">
		<text>Does not change which tool type GAMMA uses (grooming / swiss / multitool). Only redirects wear to the lowest-condition stack of that type that will still survive вЂ” including when you drag-and-drop a tool.</text>
	</string>
	<string id="ui_mcm_dorn_optimal_tool_use_enabled">
		<text>Enabled</text>
	</string>
	<string id="ui_mcm_dorn_optimal_tool_use_enabled_desc">
		<text>Use optimal tool selection for auto disassembly.</text>
	</string>
	<string id="ui_mcm_dorn_optimal_tool_use_development_section">
		<text>Development</text>
	</string>
	<string id="ui_mcm_dorn_optimal_tool_use_debug_overlay">
		<text>Enable debug overlay</text>
	</string>
	<string id="ui_mcm_dorn_optimal_tool_use_debug_overlay_desc">
		<text>Show which tool was auto-selected for disassembly in the debug overlay.</text>
	</string>
	<string id="ui_mcm_dorn_optimal_tool_use_debug_log">
		<text>Enable debug logging</text>
	</string>
	<string id="ui_mcm_dorn_optimal_tool_use_debug_log_desc">
		<text>Write which tool was auto-selected for disassembly to the game log file.</text>
	</string>
</string_table>
